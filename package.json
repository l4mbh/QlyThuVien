{
  "name": "qlythuvien-monorepo",
  "private": true,
  "description": "Library Management System Monorepo",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:shared": "pnpm --filter @qltv/shared dev",
    "dev:admin": "pnpm --filter @qltv/web dev",
    "dev:reader": "pnpm --filter @qltv/reader dev",
    "dev:api": "pnpm --filter @qltv/api dev",
    "build": "pnpm -r build",
    "build:shared": "pnpm --filter @qltv/shared build",
    "build:admin": "pnpm --filter @qltv/web build",
    "build:reader": "pnpm --filter @qltv/reader build",
    "clean": "pnpm -r exec rm -rf node_modules dist",
    "db:push": "pnpm --filter @qltv/api exec prisma db push",
    "db:studio": "pnpm --filter @qltv/api exec prisma studio",
    "install:all": "pnpm install"
  },
  "devDependencies": {
    "supabase": "^2.95.3",
    "typescript": "^5.0.0"
  },
  "pnpm": {
    "allowedBuiltDependencies": [
      "supabase"
    ]
  }
}
