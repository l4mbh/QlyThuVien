generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  STAFF
  READER
}

enum UserStatus {
  ACTIVE
  BLOCKED
}

enum BorrowRecordStatus {
  BORROWING
  OVERDUE
  COMPLETED
}

enum BorrowItemStatus {
  BORROWING
  RETURNED
  OVERDUE
}

enum InventoryLogReason {
  RESTOCK
  DAMAGED
  LOST
  MANUAL_ADJUST
}

model User {
  id                 String          @id @default(uuid())
  name               String
  email              String          @unique
  password           String
  role               UserRole        @default(STAFF)
  status             UserStatus      @default(ACTIVE)
  borrowLimit        Int             @default(5)
  currentBorrowCount Int             @default(0)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  borrowRecords      BorrowRecord[]
  inventoryLogs      InventoryLog[]
  auditLogs          AuditLog[]
  notifications      Notification[]

  @@map("users")
}

model Category {
  id        String   @id @default(uuid())
  name      String
  code      String?
  createdAt DateTime @default(now())
  books     Book[]

  @@map("categories")
}

model Book {
  id                String     @id @default(uuid())
  title             String
  author            String
  isbn              String     @unique
  totalQuantity     Int
  availableQuantity Int
  isArchived        Boolean    @default(false)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  borrowItems       BorrowItem[]
  categoryId        String?
  category          Category?  @relation(fields: [categoryId], references: [id])
  callNumber        String?
  coverUrl          String?
  inventoryLogs     InventoryLog[]

  @@map("books")
}

model BorrowRecord {
  id          String             @id @default(uuid())
  userId      String
  user        User               @relation(fields: [userId], references: [id])
  borrowDate  DateTime           @default(now())
  dueDate     DateTime
  status      BorrowRecordStatus @default(BORROWING)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  borrowItems BorrowItem[]

  @@map("borrow_records")
}

model BorrowItem {
  id             String           @id @default(uuid())
  borrowRecordId String
  borrowRecord   BorrowRecord     @relation(fields: [borrowRecordId], references: [id])
  bookId         String
  book           Book             @relation(fields: [bookId], references: [id])
  status         BorrowItemStatus @default(BORROWING)
  borrowedAt     DateTime         @default(now())
  fineAmount     Int?
  returnedAt     DateTime?
  updatedAt      DateTime         @updatedAt

  @@map("borrow_items")
}

model InventoryLog {
  id        String             @id @default(uuid())
  bookId    String
  book      Book               @relation(fields: [bookId], references: [id])
  change    Int
  reason    InventoryLogReason
  note      String?
  userId    String
  user      User               @relation(fields: [userId], references: [id])
  createdAt DateTime           @default(now())

  @@map("inventory_logs")
}

model AuditLog {
  id         String   @id @default(uuid())
  action     String
  entityType String
  entityId   String
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  metadata   Json?
  createdAt  DateTime @default(now())

  @@map("audit_logs")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  title     String
  message   String?
  metadata  Json?    @default("{}")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("notifications")
}
